{
  // 日志配置
  "log": {
    "level": "warn", // 日志级别：仅显示警告及错误
    "timestamp": true // 在日志中显示时间戳
  },
  // DNS 配置
  "dns": {
    "servers": [
      {
        "tag": "direct-dns",
        "address": "https://223.5.5.5/dns-query", // 阿里 DNS (DoH)
        "detour": "DIRECT", // 直连访问
        "strategy": "prefer_ipv4"
      },
      {
        "tag": "proxy-dns",
        "address": "https://8.8.8.8/dns-query", // Google DNS (DoH)
        "detour": "PROXY", // 修改：通过 PROXY 出站解析，不再通过 LLM-WG
        "strategy": "prefer_ipv4"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "direct-dns" // 默认所有出站优先使用直连 DNS
      },
      {
        "domain_keyword": [
          "openai", "anthropic", "claude", "mistral",
          "groq", "cohere", "perplexity", "grok", "x.ai", "xai.com", "chatgpt", "oaistatic", "oaiusercontent"
        ],
        "server": "proxy-dns" // AI 相关域名使用 proxy-dns 解析
      },
      {
        "rule_set": ["geosite-geolocation-!cn"],
        "server": "proxy-dns" // 中国以外的域名使用 proxy-dns 解析
      }
    ],
    "final": "direct-dns",
    "independent_cache": true // 启用独立缓存
  },
  // 入站设置
  "inbounds": [
    {
      "type": "tun", // TUN 模式（虚拟网卡）
      "tag": "tun-in",
      "address": [
        "172.19.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "auto_route": true, // 自动设置路由表
      "strict_route": true, // 强制所有流量通过 TUN
      "stack": "system", // 使用系统网络栈
      "sniff": true, // 启用流量嗅探（识别域名）
      "sniff_override_destination": true
    }
  ],
  // 终端节点配置（如 WireGuard）
  "endpoints": [
    {
      "type": "wireguard",
      "tag": "LLM-WG",
      "address": [
        "10.0.0.2/32"
      ],
      "private_key": "4E8WW05lzodksKH+Y/hn+XM/7tOfyLYR12BXQZbEU1U=",
      "mtu": 1420,
      "peers": [
        {
          "address": "13.213.44.125",
          "port": 51820,
          "public_key": "fPOuDyxijX6mb1lsqbkYyyKowrlUC/bGRvKqTNb7+Us=",
          "allowed_ips": [
            "0.0.0.0/0",
            "::/0"
          ],
          "persistent_keepalive_interval": 25
        }
      ]
    }
  ],
  // 出站节点配置
  "outbounds": [
    {
      "type": "selector", // 选择器：手动切换 CDN 节点
      "tag": "PROXY",
      "outbounds": ["CDN-1", "CDN-2", "CDN-3"],
      "default": "CDN-1"
    },
    {
      "type": "selector", // 选择器：LLM 专用出站
      "tag": "LLM",
      "outbounds": ["LLM-WG"],
      "default": "LLM-WG"
    },
    {
      "type": "vless",
      "tag": "CDN-1",
      "server": "8.35.211.251",
      "server_port": 443,
      "uuid": "723f6692-87a0-4a59-848d-8112b4e0db5b",
      "tls": {
        "enabled": true,
        "server_name": "ddns.hayoovant.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        }
      },
      "transport": {
        "type": "ws",
        "path": "/",
        "headers": { "Host": "ddns.hayoovant.com" }
      }
    },
    {
      "type": "vless",
      "tag": "CDN-2",
      "server": "104.27.26.10",
      "server_port": 443,
      "uuid": "5f2616c7-a69c-4a56-94b0-2aa4a25f878f",
      "tls": {
        "enabled": true,
        "server_name": "helloworld.todsm.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        }
      },
      "transport": {
        "type": "ws",
        "path": "/",
        "headers": { "Host": "helloworld.todsm.com" }
      }
    },
    {
      "type": "vless",
      "tag": "CDN-3",
      "server": "172.66.208.146",
      "server_port": 443,
      "uuid": "351e3c90-7f9f-4f40-bccc-bee0bb0ca951",
      "tls": {
        "enabled": true,
        "server_name": "helloworld.fotoman.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        }
      },
      "transport": {
        "type": "ws",
        "path": "/",
        "headers": { "Host": "helloworld.fotoman.com" }
      }
    },
    {
      "type": "direct",
      "tag": "DIRECT"
    }
  ],
  // 路由分流配置
  "route": {
    "rules": [
      {
        "action": "sniff" // 执行流量嗅探
      },
      {
        "protocol": "dns",
        "action": "hijack-dns" // 劫持 DNS 请求到内部服务器
      },
      {
        "ip_is_private": true,
        "action": "direct" // 私有 IP（局域网）直接连接
      },
// ==================== 规则01：AI 相关分流 ====================
      {
        "domain_keyword": [
          "openai", "anthropic", "claude", "mistral",
          "groq", "cohere", "perplexity", "grok", "x.ai", "xai.com", "chatgpt", "oaistatic", "oaiusercontent"
        ],
        "action": "route",
        "outbound": "LLM"
      },
      
      {
        "domain_keyword": [
          "linked", "licdn", "lnkd"
        ],
        "action": "route",
        "outbound": "PROXY"
      },

      {
        "ip_cidr": [
          "108.174.0.0/20",
          "185.63.144.0/22",
          "13.107.42.0/24"
        ],
        "action": "route",
        "outbound": "LLM"
      },

      {
        "ip_cidr": [
          "13.107.238.0/24",
          "13.107.239.0/24"
        ],
        "action": "route",
        "outbound": "LLM"
      },
// ==================== 规则01：结束 ====================
      {
        "rule_set": ["geoip-cn"],
        "action": "route",
        "outbound": "DIRECT" // 中国大陆 IP 直连
      },
      {
        "rule_set": ["geosite-geolocation-!cn"],
        "invert": true,
        "action": "route",
        "outbound": "DIRECT" // 如果不是非中国区网站，则直连（兜底国内逻辑）
      },
      {
        "rule_set": [
          "geosite-category-ads-all"
        ],
        "action": "reject" // 拒绝/拦截广告
      },
      {
        "rule_set": ["geoip-cn"],
        "invert": true,
        "action": "route",
        "outbound": "PROXY" // 非中国 IP 走代理
      },

// ==================== 规则02：白名单直连 ====================
      {
        "domain_suffix": [
          "apollo.io", "apollo", "helium10", "myshopline", "shopline", "Sortime", "semrush", "quanmaitong", "sif.com", "garmin", "wahoo", "komoot"
        ],
        "action": "route",
        "outbound": "DIRECT"
      }
// ==================== 规则02：结束 ====================

    ],
    // 远程规则集定义
    "rule_set": [
      {
        "tag": "geosite-geolocation-!cn",
        "type": "remote",
        "format": "binary",
        "url": "https://gh.090227.xyz/https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-!cn.srs",
        "download_detour": "PROXY"
      },
      {
        "tag": "geosite-category-ads-all",
        "type": "remote",
        "format": "binary",
        "url": "https://gh.090227.xyz/https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs",
        "download_detour": "PROXY"
      },
      {
        "tag": "geoip-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://gh.090227.xyz/https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs",
        "download_detour": "PROXY"
      }
    ],
    "final": "DIRECT", // 最终默认行为：直连
    "auto_detect_interface": true // 自动检测网卡
  },
  // 实验性功能及 Clash API
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db" // 启用缓存文件以提高性能
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090", // 控制台地址
      "external_ui": "ui", // 界面目录
      "secret": "", // API 密钥
      "external_ui_download_url": "https://github.com/MetaCubeX/metacubexd/archive/gh-pages.zip",
      "external_ui_download_detour": "PROXY"
    }
  }
}
