{
  // 日志设置：用于排查连接问题
  "log": {
    "level": "warn", // 日志级别，设置为 warn 减少磁盘写入并过滤无用信息
    "timestamp": true // 开启时间戳，方便定位故障发生时间
  },
  // DNS 调度中心：处理域名解析与防污染
  "dns": {
    "servers": [
      {
        "tag": "direct-dns",
        "address": "https://223.5.5.5/dns-query", // 阿里 DoH，用于国内域名直连解析
        "detour": "DIRECT", // 强制走本地网络，确保解析速度最快
        "strategy": "prefer_ipv4"
      },
      {
        "tag": "proxy-dns",
        "address": "https://8.8.8.8/dns-query", // Google DoH，用于海外/AI域名解析
        "detour": "PROXY", // 核心修改：流量加密通过代理发出，彻底解决解析污染
        "strategy": "prefer_ipv4"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "direct-dns" // 默认规则：优先使用国内 DNS
      },
      {
        "domain_keyword": [
          "openai", "anthropic", "claude", "gemini", "aistudio.google.com", "ai.google.dev", "mistral",
          "groq", "cohere", "perplexity", "grok", "x.ai", "xai.com", "chatgpt", "oaistatic", "oaiusercontent"
        ],
        "server": "proxy-dns" // AI 类域名强制走远程 DNS 解析
      },
      {
        "rule_set": ["geosite-geolocation-!cn"],
        "server": "proxy-dns" // 非中国大陆域名强制走远程 DNS 解析
      }
    ],
    "final": "direct-dns", // 默认兜底 DNS
    "independent_cache": true // 开启独立缓存，提高二次访问解析速度
  },
  // 入站协议：接管系统流量
  "inbounds": [
    {
      "type": "tun", // 虚拟网卡模式，接管整机流量
      "tag": "tun-in",
      "address": [
        "172.19.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "auto_route": true, // 自动修改系统路由表
      "strict_route": true, // 严格路由，防止流量泄露
      "stack": "system", // 使用系统网络栈，稳定性较好
      "sniff": true, // 开启流量嗅探，用于识别 TLS 域名进行精确分流
      "sniff_override_destination": true
    }
  ],
  // 协议端点：定义 WireGuard 等特殊通道
  "endpoints": [
    {
      "type": "wireguard",
      "tag": "LLM-WG",
      "address": [
        "10.0.0.2/32"
      ],
      "private_key": "4E8WW05lzodksKH+Y/hn+XM/7tOfyLYR12BXQZbEU1U=",
      "mtu": 1420,
      "peers": [
        {
          "address": "13.213.44.125",
          "port": 51820,
          "public_key": "fPOuDyxijX6mb1lsqbkYyyKowrlUC/bGRvKqTNb7+Us=",
          "allowed_ips": [
            "0.0.0.0/0",
            "::/0"
          ],
          "persistent_keepalive_interval": 25
        }
      ]
    }
  ],
  // 出站节点：流量发送的目的地
  "outbounds": [
    {
      "type": "selector", // 手动选择器：用于日常网页浏览
      "tag": "PROXY",
      "outbounds": ["CDN-1", "CDN-2", "CDN-3"],
      "default": "CDN-1"
    },
    {
      "type": "selector", // AI 专用出站：通过指定 WireGuard 落地
      "tag": "LLM",
      "outbounds": ["LLM-WG"],
      "default": "LLM-WG"
    },
    {
      "type": "vless",
      "tag": "CDN-1",
      "server": "8.35.211.251",
      "server_port": 443,
      "uuid": "723f6692-87a0-4a59-848d-8112b4e0db5b",
      "tls": {
        "enabled": true,
        "server_name": "ddns.hayoovant.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        }
      },
      "transport": {
        "type": "ws",
        "path": "/",
        "headers": { "Host": "ddns.hayoovant.com" }
      }
    },
    {
      "type": "vless",
      "tag": "CDN-2",
      "server": "104.27.26.10",
      "server_port": 443,
      "uuid": "5f2616c7-a69c-4a56-94b0-2aa4a25f878f",
      "tls": {
        "enabled": true,
        "server_name": "helloworld.todsm.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        }
      },
      "transport": {
        "type": "ws",
        "path": "/",
        "headers": { "Host": "helloworld.todsm.com" }
      }
    },
    {
      "type": "vless",
      "tag": "CDN-3",
      "server": "172.66.208.146",
      "server_port": 443,
      "uuid": "351e3c90-7f9f-4f40-bccc-bee0bb0ca951",
      "tls": {
        "enabled": true,
        "server_name": "helloworld.fotoman.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        }
      },
      "transport": {
        "type": "ws",
        "path": "/",
        "headers": { "Host": "helloworld.fotoman.com" }
      }
    },
    {
      "type": "direct",
      "tag": "DIRECT"
    }
  ],
  // 路由引擎：流量分流的核心逻辑
  "route": {
    "rules": [
      {
        "action": "sniff" // 嗅探流量以获取域名信息进行分流
      },
      {
        "protocol": "dns",
        "action": "hijack-dns" // 劫持所有标准 DNS 请求到内部 DNS 调度中心
      },
      {
        "ip_is_private": true,
        "action": "direct" // 私有网段流量不走代理，直接连接
      },
// ==================== AI 流量规则专区 ====================
      {
        "domain_keyword": [
          "openai", "anthropic", "claude", "gemini", "aistudio.google.com", "ai.google.dev", "mistral",
          "groq", "cohere", "perplexity", "grok", "x.ai", "xai.com", "chatgpt", "oaistatic", "oaiusercontent"
        ],
        "action": "route",
        "outbound": "LLM" // AI 域名统一通过 LLM-WG 出站
      },
      
      {
        "domain_keyword": [
          "linked", "licdn", "lnkd"
        ],
        "action": "route",
        "outbound": "PROXY" // 职场社交流量走 PROXY 出站
      },

      {
        "ip_cidr": [
          "108.174.0.0/20",
          "185.63.144.0/22",
          "13.107.42.0/24"
        ],
        "action": "route",
        "outbound": "LLM" // 特定 AI 服务 IP 段走 LLM-WG
      },

      {
        "ip_cidr": [
          "13.107.238.0/24",
          "13.107.239.0/24"
        ],
        "action": "route",
        "outbound": "LLM"
      },
// ==================== 常规分流规则 ====================
      {
        "rule_set": ["geoip-cn"],
        "action": "route",
        "outbound": "DIRECT" // 中国大陆 IP 直接连接
      },
      {
        "rule_set": ["geosite-geolocation-!cn"],
        "invert": true,
        "action": "route",
        "outbound": "DIRECT" // 逻辑取反：若不在非中国库中，默认直连（增强国内访问）
      },
      {
        "rule_set": [
          "geosite-category-ads-all"
        ],
        "action": "reject" // 广告拦截规则
      },
      {
        "rule_set": ["geoip-cn"],
        "invert": true,
        "action": "route",
        "outbound": "PROXY" // 识别为国外 IP 的流量走代理
      },

// ==================== 个人白名单：强制直连 ====================
      {
        "domain_suffix": [
          "apollo.io", "apollo", "helium10", "myshopline", "shopline", "Sortime", "semrush", "quanmaitong", "sif.com", "garmin", "wahoo", "komoot"
        ],
        "action": "route",
        "outbound": "DIRECT" // 指定办公及运动品牌域名直连，保证低延迟
      }
// ==================== 规则结束 ====================

    ],
    // 远程资源库：自动更新规则集
    "rule_set": [
      {
        "tag": "geosite-geolocation-!cn",
        "type": "remote",
        "format": "binary",
        "url": "https://gh.090227.xyz/https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-!cn.srs",
        "download_detour": "PROXY"
      },
      {
        "tag": "geosite-category-ads-all",
        "type": "remote",
        "format": "binary",
        "url": "https://gh.090227.xyz/https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs",
        "download_detour": "PROXY"
      },
      {
        "tag": "geoip-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://gh.090227.xyz/https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs",
        "download_detour": "PROXY"
      }
    ],
    "final": "DIRECT", // 兜底策略：未匹配规则流量直连
    "auto_detect_interface": true // 自动识别本地网卡，防止回环
  },
  // 实验性增强功能
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db" // 记录解析结果，减少后续连接建立时间
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090", // 面板控制端口
      "external_ui": "ui", // 指定 UI 文件存放目录
      "secret": "", // API 验证密钥
      "external_ui_download_url": "https://github.com/MetaCubeX/metacubexd/archive/gh-pages.zip",
      "external_ui_download_detour": "PROXY"
    }
  }
}
